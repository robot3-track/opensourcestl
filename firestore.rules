rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // Project Validation Helper
    function isValidProject(project) {
      return project.name is string && project.name.size() > 0 && project.name.size() <= 100
        && project.ownerId is string && project.ownerId == request.auth.uid
        && project.shapes is list && project.shapes.size() <= 100;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isValidProject(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && existing().ownerId == request.auth.uid
        && isValidProject(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasAny(['name', 'shapes', 'updatedAt']);
        
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
